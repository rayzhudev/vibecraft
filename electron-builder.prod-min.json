{
  "extends": "./electron-builder.json",
  "artifactName": "${productName}-prod-min-${version}-${arch}.${ext}",
  "directories": {
    "output": "release/prod-min"
  },
  "electronLanguages": ["en"],
  "files": [
    "dist/**/*",
    "package.json",
    "assets/tutorial/**/*",
    "node_modules/**/*",
    "!**/*.map",
    "!**/node_modules/posthog-js/**",
    "!**/node_modules/@opentelemetry/**",
    "!**/node_modules/@playwright/**",
    "!**/node_modules/@testing-library/**",
    "!**/node_modules/@types/**",
    "!**/node_modules/@vitejs/**",
    "!**/node_modules/@vitest/**",
    "!**/node_modules/@eslint/**",
    "!**/node_modules/protobufjs/**",
    "!**/node_modules/core-js/**",
    "!**/node_modules/electron/**",
    "!**/node_modules/electron-builder/**",
    "!**/node_modules/electron-rebuild/**",
    "!**/node_modules/eslint/**",
    "!**/node_modules/eslint-plugin-react/**",
    "!**/node_modules/eslint-plugin-react-hooks/**",
    "!**/node_modules/eslint-plugin-react-refresh/**",
    "!**/node_modules/globals/**",
    "!**/node_modules/jsdom/**",
    "!**/node_modules/playwright/**",
    "!**/node_modules/prettier/**",
    "!**/node_modules/preact/**",
    "!**/node_modules/react/**",
    "!**/node_modules/react-dom/**",
    "!**/node_modules/dompurify/**",
    "!**/node_modules/typescript/**",
    "!**/node_modules/typescript-eslint/**",
    "!**/node_modules/vite/**",
    "!**/node_modules/vite-plugin-electron/**",
    "!**/node_modules/vite-plugin-electron-renderer/**",
    "!**/node_modules/vitest/**",
    "!**/node_modules/xterm/**",
    "!**/node_modules/xterm-addon-fit/**",
    "!**/node_modules/@agentconnect/host/node_modules/node-pty/**",
    "!**/node_modules/**/node-pty/src/**",
    "!**/node_modules/**/node-pty/scripts/**",
    "!**/node_modules/**/node-pty/deps/**",
    "!**/node_modules/**/node-pty/prebuilds/darwin-x64/**",
    "!**/node_modules/**/node-pty/prebuilds/linux-*/**",
    "!**/node_modules/**/node-pty/prebuilds/win32-*/**",
    "!**/node_modules/**/node-pty/bin/darwin-x64*/**",
    "!**/node_modules/**/node-pty/lib/**/*.test.*",
    "!**/node_modules/**/node-pty/src/**/*.test.*",
    "!**/node_modules/**/node-pty/**/*.md",
    "!**/node_modules/**/node-pty/.editorconfig"
  ]
}
